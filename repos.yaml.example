# Registry of repositories the bug-fixer is responsible for.
#
# Each entry MUST include `url` and `default_branch`. All other fields are
# optional metadata that helps Claude work efficiently on the codebase.
#
# `display_names` is the bridge between free-text Hebrew project names that
# customers/triagers write into Firestore tickets and the actual GitHub
# repository the fix should go into. Matching is case-insensitive and
# whitespace-tolerant. List every variation you see in real tickets — the
# resolver does NOT do fuzzy matching.
#
# `forbidden_paths` lists files Claude is NEVER allowed to touch when
# fixing bugs in this repo (e.g. secret config, deployment hooks).

# IMPORTANT: there is also an OLD `talya-debug/Argaman` repository — it is
# inactive and must NOT be touched. All Argaman tickets go to argaman-new.

# Forbidden paths apply per Talya's policy:
#   .env, .env.local, firebase.js, lib/firebase.js, vercel.json,
#   package-lock.json, yarn.lock

_anchors:
  forbidden_paths_default: &forbidden
    - .env
    - .env.local
    - firebase.js
    - lib/firebase.js
    - vercel.json
    - package-lock.json
    - yarn.lock

repos:
  - url: https://github.com/talya-debug/argaman-new
    default_branch: master
    language: javascript
    framework: react
    test_command: npm test --silent
    description: |
      Argaman storefront. React + Firebase. Hebrew RTL UI throughout.
      Deployed on Vercel — every PR gets an automatic preview URL.
    display_names:
      - "ארגמן"
    forbidden_paths: *forbidden

  - url: https://github.com/talya-debug/yishai-yosef
    default_branch: main
    language: javascript
    framework: react
    test_command: npm test --silent
    description: |
      Yishai-Yosef storefront. Same stack as Argaman.
    display_names:
      - "ישי יוסף"
    forbidden_paths: *forbidden

  - url: https://github.com/talya-debug/yael_siso
    default_branch: master
    language: javascript
    framework: react
    test_command: npm test --silent
    display_names:
      - "יעל סיסו"
    forbidden_paths: *forbidden

  - url: https://github.com/talya-debug/lia-fine-jewelry
    default_branch: master
    language: javascript
    framework: react
    test_command: npm test --silent
    display_names:
      - "ליה"
      - "LIA"
    forbidden_paths: *forbidden
