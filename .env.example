# ---------- Anthropic ----------
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
CLAUDE_MAX_TOOL_ITERATIONS=25
CLAUDE_MAX_OUTPUT_TOKENS=8192

# ---------- Firestore (bug source) ----------
# Bugs are read from a Firebase Firestore collection over the public REST
# API. The project's web API key is enough — Firestore Security Rules are
# what authorize reads/writes (the API key alone gives no permissions).
#
# Both fields are required.
FIREBASE_PROJECT_ID=service-tickets-cb56a
FIREBASE_API_KEY=AIzaSy...

# Override only when targeting the local Firestore emulator.
FIRESTORE_BASE_URL=https://firestore.googleapis.com/v1
FIRESTORE_REQUEST_TIMEOUT_SECONDS=15

# Firestore collection containing the tickets.
FIRESTORE_COLLECTION=tickets

# Document field names — override only if your schema is different.
FIRESTORE_STATUS_FIELD=status
FIRESTORE_TYPE_FIELD=type
FIRESTORE_DESCRIPTION_FIELD=description
FIRESTORE_EMAIL_FIELD=email
FIRESTORE_PROJECT_FIELD=project
FIRESTORE_CUSTOMER_NAME_FIELD=name
FIRESTORE_IMAGES_FIELD=images
FIRESTORE_PR_URL_FIELD=pr_url
FIRESTORE_AI_NOTES_FIELD=ai_notes

# Only tickets matching this `type` field are picked up. Set to empty to
# disable the filter.
FIRESTORE_TYPE_FILTER=bug

# Status state machine — values written back into FIRESTORE_STATUS_FIELD.
BUG_STATUS_NEW=open
BUG_STATUS_PROCESSING=processing
BUG_STATUS_MR_OPENED=mr_opened
BUG_STATUS_FAILED=failed

# Hard cap on the number of tickets processed in one tick.
MAX_BUGS_PER_RUN=3

# ---------- Daemon loop ----------
POLL_INTERVAL_SECONDS=30
IDLE_BACKOFF_SECONDS=60
ERROR_BACKOFF_SECONDS=120

# ---------- GitHub ----------
# Personal Access Token with `repo` scope, or fine-grained token w/ contents+pull_requests write.
GITHUB_TOKEN=ghp_...
GITHUB_API_URL=https://api.github.com
GIT_COMMITTER_NAME=auto-bug-fixer
[email protected]

# ---------- SMTP (optional) ----------
# Email is OFF by default. The pipeline still opens PRs, it just doesn't
# send the confirmation email. Flip to true and fill in the SMTP_* fields
# below to enable email notifications.
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=[email protected]
# For Gmail, use an App Password (https://myaccount.google.com/apppasswords).
SMTP_PASSWORD=app-password
[email protected]
NOTIFY_CC=

# ---------- Sandbox ----------
WORKSPACE_DIR=/tmp/auto-bug-fixer
GIT_OPERATION_TIMEOUT_SECONDS=300

# ---------- Repo registry + indexing ----------
REPOS_FILE=repos.yaml
INDEX_DIR=indexes
REINDEX_INTERVAL_HOURS=24
INDEX_ON_STARTUP=true

# ---------- Health endpoint ----------
HEALTH_ENABLED=true
HEALTH_HOST=0.0.0.0
HEALTH_PORT=8080
HEALTH_STALE_AFTER_SECONDS=900

# ---------- Logging ----------
LOG_LEVEL=INFO
LOG_FORMAT=json
