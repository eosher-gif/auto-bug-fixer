# ---------- Anthropic ----------
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
CLAUDE_MAX_TOOL_ITERATIONS=25
CLAUDE_MAX_OUTPUT_TOKENS=8192

# ---------- Bug Database ----------
# Any SQLAlchemy URL: postgresql+psycopg2://user:pass@host:5432/db, mysql+pymysql://..., sqlite:///./bugs.db
DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/bugs

# Map your existing schema -> the columns we read.
BUG_TABLE_NAME=customer_bugs
BUG_ID_COLUMN=id
BUG_TITLE_COLUMN=title
BUG_DESCRIPTION_COLUMN=description
BUG_STATUS_COLUMN=status
BUG_REPO_URL_COLUMN=repo_url
BUG_REPO_BRANCH_COLUMN=base_branch
BUG_REPORTER_EMAIL_COLUMN=reporter_email

# State-machine values used in BUG_STATUS_COLUMN.
BUG_STATUS_NEW=new
BUG_STATUS_PROCESSING=processing
BUG_STATUS_MR_OPENED=mr_opened
BUG_STATUS_FAILED=failed

# Max bugs handled per loop iteration.
MAX_BUGS_PER_RUN=3

# ---------- Daemon loop ----------
# Sleep between iterations when there WAS work in the previous tick.
POLL_INTERVAL_SECONDS=30
# Sleep when DB had no pending bugs (back off to reduce DB load).
IDLE_BACKOFF_SECONDS=60
# Sleep when an unhandled exception bubbled up (avoid hot-loop crashes).
ERROR_BACKOFF_SECONDS=120

# ---------- GitHub ----------
# Personal Access Token with `repo` scope, or fine-grained token w/ contents+pull_requests write.
GITHUB_TOKEN=ghp_...
GITHUB_API_URL=https://api.github.com
# Used in commit author + git push URL.
GIT_COMMITTER_NAME=auto-bug-fixer
[email protected]

# ---------- SMTP ----------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=[email protected]
# For Gmail, use an App Password (https://myaccount.google.com/apppasswords).
SMTP_PASSWORD=app-password
[email protected]
NOTIFY_CC=

# ---------- Sandbox ----------
# Where cloned repos live during processing. /tmp on Linux runners.
WORKSPACE_DIR=/tmp/auto-bug-fixer
GIT_OPERATION_TIMEOUT_SECONDS=300

# ---------- Repo registry + indexing ----------
# YAML file listing every repo the bug-fixer is responsible for.
REPOS_FILE=repos.yaml
# Where per-repo index JSON files are persisted.
# - GitHub Actions runtime: keep the default `indexes` (committed to the repo).
# - VM/Docker runtime:      override to a persistent path like /var/auto-bug-fixer/index.
INDEX_DIR=indexes
# How often the daemon re-indexes every repo (hours). Daemon-mode only.
REINDEX_INTERVAL_HOURS=24
# Daemon-mode only: build a fresh index for every repo on startup.
INDEX_ON_STARTUP=true

# ---------- Health endpoint ----------
HEALTH_ENABLED=true
HEALTH_HOST=0.0.0.0
HEALTH_PORT=8080
# If no successful tick happened in N seconds, /health returns 503.
HEALTH_STALE_AFTER_SECONDS=900

# ---------- Logging ----------
LOG_LEVEL=INFO
LOG_FORMAT=json
